{
  "name": "pal-optical-forms",
  "version": "1.0.0",
  "description": "Professional shop forms for Pal Optical",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "vite",
    "build": "node build.js",
    "preview": "vite preview",
    "server:dev": "node --loader ts-node/esm server.ts",
    "start": "npm run build && node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "ts-node": "^10.9.2"
  }
}
